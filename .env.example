# Configuration Edilkamin - Fichier Template
# ATTENTION: Ne jamais committer ce fichier avec tes vraies données!
# Crée un fichier .env.local et .env basé sur ce template

# Credentials Edilkamin
EDILKAMIN_USERNAME=your_email@example.com
EDILKAMIN_PASSWORD=your_password_here
EDILKAMIN_MAC=00:00:00:00:00:00

# Options
EDILKAMIN_USE_LEGACY_API=false
EDILKAMIN_TIMEOUT=10
EDILKAMIN_UPDATE_INTERVAL=60

